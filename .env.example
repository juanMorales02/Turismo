# Puerto del servidor
PORT=3000

# Conexión a MongoDB (Atlas o local)
MONGODB_URI=mongodb+srv://usuario:tu_password@cluster0.xxxxx.mongodb.net/mi_base_de_datos?retryWrites=true&w=majority

# Clave secreta para firmar los JWT (mínimo 32 caracteres)
JWT_SECRET=your_super_secret_jwt_key_change_this_to_a_long_random_string
JWT_EXPIRES_IN=1d

# API key de Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Entorno
NODE_ENV=development
